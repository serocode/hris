{
	"extends": "../../packages/tsconfig/api.json",
	"compilerOptions": {
		"moduleResolution": "Bundler",
		"module": "ESNext",
		"target": "ESNext",
		"strict": true,
		"jsx": "react-jsx",
		"jsxImportSource": "hono/jsx",
		"paths": {
			"@/*": ["./src/*"],
			"@tests/*": ["./tests/*"]
		}
	},
	"include": ["src/**/*", "tests/**/*"],
	"exclude": ["node_modules", "dist"]
}
