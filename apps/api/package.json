{
	"name": "@hris-v2/api",
	"dependencies": {
		"@hono/node-server": "^1.19.6",
		"@hono/zod-openapi": "^1.1.3",
		"@scalar/hono-api-reference": "^0.9.34",
		"better-auth": "^1.4.18",
		"bullmq": "^5.66.5",
		"close-with-grace": "^2.4.0",
		"dayjs": "^1.11.19",
		"drizzle-orm": "^0.45.1",
		"hono": "^4.11.9",
		"hono-pino": "^0.10.3",
		"ioredis": "^5.9.1",
		"nodemailer": "^7.0.12",
		"pg": "^8.16.3",
		"pino": "^10.2.0",
		"pino-pretty": "^13.1.3",
		"postgres": "^3.4.8",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@hris-v2/contracts": "workspace:*",
		"@hris-v2/tsconfig": "workspace:*",
		"@hris-v2/utils": "workspace:*",
		"@node-rs/argon2": "^2.0.2",
		"@types/node": "^24.10.7",
		"@types/nodemailer": "^7.0.5",
		"@types/pg": "^8.16.0",
		"@vitest/coverage-v8": "^3.1.4",
		"dotenv-cli": "^11.0.0",
		"drizzle-kit": "^0.31.8",
		"rate-limit-redis": "^4.2.3",
		"stoker": "^2.0.1",
		"tsx": "^4.7.1",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	},
	"scripts": {
		"auth-docs": "open-cli http://api.hris.localhost/api/auth/reference",
		"auth:generate": "dotenv -e ../../.env -- npx @better-auth/cli generate --config src/lib/auth.ts",
		"build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
		"check-types": "tsc --noEmit",
		"dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
		"dk": "dotenv -e ../../.env -- drizzle-kit",
		"generate": "dotenv -e ../../.env -- drizzle-kit generate",
		"kit:up": "dotenv -e ../../.env -- drizzle-kit up",
		"lint": "biome check .",
		"migrate": "dotenv -e ../../.env -- tsx src/migrate.ts",
		"start": "dotenv -e ../../.env -- node dist/index.js",
		"studio": "dotenv -e ../../.env -- drizzle-kit studio --verbose",
		"test": "NODE_ENV=test dotenv -e ../../.env.example -- vitest run",
		"test:coverage": "NODE_ENV=test dotenv -e ../../.env.example -- vitest run --coverage",
		"test:watch": "NODE_ENV=test dotenv -e ../../.env.example -- vitest"
	},
	"type": "module"
}
