{
	"$schema": "https://biomejs.dev/schemas/2.3.11/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"defaultBranch": "main"
	},
	"files": {
		"ignoreUnknown": false,
		"includes": ["**/*.{ts,tsx,js,jsx,json}", "!**/*.gen.ts"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"useAltText": "error"
			},
			"correctness": {
				"noUnusedVariables": "error",
				"noUnusedImports": "error"
			},
			"suspicious": {
				"noExplicitAny": "error"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "asNeeded"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on",
				"useSortedProperties": "on"
			}
		}
	},
	"overrides": [
		{
			"includes": ["apps/ui/**"],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": {
							"level": "error",
							"options": {
								"paths": {
									"@hris-v2/contracts": "Use subpath imports like @hris-v2/contracts/me or @hris-v2/contracts/errors."
								},
								"patterns": [
									{
										"group": [
											"apps/api/*",
											"apps/api/**",
											"@hris-v2/api",
											"@hris-v2/api/*"
										],
										"message": "UI must not import API implementation details."
									}
								]
							}
						}
					}
				}
			}
		},
		{
			"includes": ["apps/api/**"],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": {
							"level": "error",
							"options": {
								"paths": {
									"@hris-v2/contracts": "Use subpath imports like @hris-v2/contracts/me or @hris-v2/contracts/errors."
								}
							}
						}
					}
				}
			}
		},
		{
			"includes": ["packages/contracts/**"],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": {
							"level": "error",
							"options": {
								"patterns": [
									{
										"group": ["@hono/*", "hono", "hono/*"],
										"message": "Contracts must be framework-agnostic."
									},
									{
										"group": [
											"apps/api/*",
											"apps/api/**",
											"apps/ui/*",
											"apps/ui/**"
										],
										"message": "Contracts must not depend on app code."
									}
								]
							}
						}
					}
				}
			}
		}
	]
}
